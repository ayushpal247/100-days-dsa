#include <stdio.h>

int main() {
    int p, q;

    // Read first log
    if (scanf("%d", &p) != 1) return 0;
    int log1[p];
    for (int i = 0; i < p; i++) scanf("%d", &log1[i]);

    // Read second log
    if (scanf("%d", &q) != 1) return 0;
    int log2[q];
    for (int i = 0; i < q; i++) scanf("%d", &log2[i]);

    int merged[p + q];
    int i = 0, j = 0, k = 0;

    // Compare elements from both logs
    while (i < p && j < q) {
        if (log1[i] <= log2[j]) {
            merged[k++] = log1[i++];
        } else {
            merged[k++] = log2[j++];
        }
    }

    // if log1 has remaining elements, add them
    while (i < p) {
        merged[k++] = log1[i++];
    }

    // if log2 has remaining elements, add them
    while (j < q) {
        merged[k++] = log2[j++];
    }

    // Print the final chronological log
    for (int m = 0; m < p + q; m++) {
        printf("%d%s", merged[m], (m == p + q - 1) ? "" : " ");
    }
    printf("\n");

    return 0;
}
