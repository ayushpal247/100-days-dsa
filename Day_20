#include <stdio.h>
#include <stdlib.h>

#define MAX_SIZE 100001

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    long long count = 0;
    long long current_sum = 0;

    /* For simplicity in C without a hash library, 
       this is the O(n^2) approach. 
    */
    for (int i = 0; i < n; i++) {
        current_sum = 0;
        for (int j = i; j < n; j++) {
            current_sum += arr[j];
            if (current_sum == 0) {
                count++;
            }
        }
    }

    printf("%lld\n", count);

    return 0;
}
